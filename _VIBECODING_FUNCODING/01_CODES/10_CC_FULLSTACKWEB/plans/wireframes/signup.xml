<page path="/signup">
    <header></header>
    <form action="/api/auth/signup">
        <title>회원가입</title>
        <error-message />
        
        <input type="email" label="이메일" required>
            <check-duplicate 
                endpoint="/api/auth/check-email" 
                debounce="500"
                success-message="사용 가능한 이메일입니다"
                error-message="이미 사용 중인 이메일입니다" />
        </input>
        <input type="text" label="사용자명" required>
            <check-duplicate 
                endpoint="/api/auth/check-username" 
                debounce="500"
                success-message="사용 가능한 사용자명입니다"
                error-message="이미 사용 중인 사용자명입니다" />
        </input>
        <input type="password" label="비밀번호" show-strength="true" required />
        <input type="password" label="비밀번호 확인" required />
        
        <button type="submit">회원가입</button>
    </form>
    <text>
        이미 계정이 있으신가요? <link href="/login">로그인</link>
    </text>
</page>
    <section id="contact" class="py-12 lg:py-20">
      <div class="px-6 max-w-md mx-auto lg:max-w-7xl lg:px-8">

        <h2 class="text-3xl lg:text-4xl font-bold mb-2">문의하기</h2>
        <p class="text-slate-500 dark:text-slate-400 text-sm mb-8 lg:mb-12">궁금한 사항이 있으시면 언제든지 연락해 주세요.</p>

        <!-- Desktop: 2-col | Mobile: stacked -->
        <div class="lg:grid lg:grid-cols-2 lg:gap-16">

          <!-- Form -->

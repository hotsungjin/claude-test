                class="w-full px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900 text-slate-900 dark:text-slate-100 outline-none focus:border-primary text-sm transition-colors"/>
            </div>
            <div>
              <label class="block text-sm font-semibold mb-2">이메일</label>

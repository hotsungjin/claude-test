<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>설성클라우드 — 스마트한 비즈니스의 시작</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@300;400;500;600;700;900&display=swap" rel="stylesheet" />
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: { sans: ['Noto Sans KR', 'system-ui', 'sans-serif'] },
          colors: {
            brand: {
              50:  '#f0f4ff',
              100: '#dce6ff',
              200: '#b9ccff',
              300: '#8aaaff',
              400: '#6b8fff',
              500: '#4f6ef7',
              600: '#3a52e8',
              700: '#2e40cc',
              800: '#2535a4',
              900: '#1e2b82',
            }
          }
        }
      }
    }
  </script>
  <style>
    body { font-family: 'Noto Sans KR', system-ui, sans-serif; }

    .nav-glass {
      background: rgba(255,255,255,0.85);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(255,255,255,0.3);
    }

    .hero-bg {
      background: linear-gradient(135deg, #f0f4ff 0%, #e8eeff 40%, #f5f0ff 100%);
    }

    .service-card {
      transition: transform 0.2s, box-shadow 0.2s;
    }
    .service-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 12px 32px rgba(79,110,247,0.12);
    }

    .testimonial-card {
      transition: transform 0.2s;
    }
    .testimonial-card:hover {
      transform: translateY(-2px);
    }

    html { scroll-behavior: smooth; }

    .fade-in {
      opacity: 0;
      transform: translateY(20px);
      transition: opacity 0.5s, transform 0.5s;
    }
    .fade-in.visible {
      opacity: 1;
      transform: translateY(0);
    }
  </style>
</head>
<body class="bg-white text-gray-800">

  <!-- Navigation -->
  <nav class="nav-glass fixed top-0 left-0 right-0 z-50">
    <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
      <a href="#" class="flex items-center gap-2">
        <div class="w-8 h-8 bg-brand-600 rounded-lg flex items-center justify-center text-white font-bold text-sm">S</div>
        <span class="font-bold text-gray-900 text-lg">설성클라우드</span>
      </a>
      <div class="hidden md:flex items-center gap-1">
        <a href="#services" class="px-4 py-2 text-sm text-gray-600 hover:text-brand-600 hover:bg-brand-50 rounded-lg transition-colors">서비스</a>
        <a href="#dashboard" class="px-4 py-2 text-sm text-gray-600 hover:text-brand-600 hover:bg-brand-50 rounded-lg transition-colors">대시보드</a>
        <a href="#testimonials" class="px-4 py-2 text-sm text-gray-600 hover:text-brand-600 hover:bg-brand-50 rounded-lg transition-colors">고객후기</a>
        <a href="#contact" class="px-4 py-2 text-sm text-gray-600 hover:text-brand-600 hover:bg-brand-50 rounded-lg transition-colors">문의</a>
      </div>
      <div class="hidden md:flex items-center gap-3">
        <a href="#" class="text-sm text-gray-600 hover:text-brand-600 transition-colors">로그인</a>
        <a href="#contact" class="px-4 py-2 text-sm bg-brand-600 text-white rounded-lg hover:bg-brand-700 transition-colors font-medium">무료 시작</a>
      </div>
      <!-- Hamburger -->
      <button id="hamburger" class="md:hidden p-2 rounded-lg hover:bg-gray-100">
        <div class="w-5 h-0.5 bg-gray-600 mb-1"></div>
        <div class="w-5 h-0.5 bg-gray-600 mb-1"></div>
        <div class="w-5 h-0.5 bg-gray-600"></div>
      </button>
    </div>
    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden md:hidden border-t border-gray-100 bg-white px-6 py-4 space-y-2">
      <a href="#services" class="block px-4 py-2 text-sm text-gray-600 hover:bg-brand-50 rounded-lg">서비스</a>
      <a href="#dashboard" class="block px-4 py-2 text-sm text-gray-600 hover:bg-brand-50 rounded-lg">대시보드</a>
      <a href="#testimonials" class="block px-4 py-2 text-sm text-gray-600 hover:bg-brand-50 rounded-lg">고객후기</a>
      <a href="#contact" class="block px-4 py-2 text-sm text-gray-600 hover:bg-brand-50 rounded-lg">문의</a>
      <a href="#contact" class="block px-4 py-2 text-sm bg-brand-600 text-white rounded-lg text-center font-medium">무료 시작</a>
    </div>
  </nav>

  <!-- Hero -->
  <section class="hero-bg pt-32 pb-20 px-6">
    <div class="max-w-4xl mx-auto text-center fade-in">
      <span class="inline-flex items-center gap-2 px-3 py-1 bg-brand-100 text-brand-700 text-xs font-semibold rounded-full mb-6">
        <span class="w-1.5 h-1.5 bg-brand-500 rounded-full"></span>
        신뢰할 수 있는 클라우드 파트너
      </span>
      <h1 class="text-4xl md:text-5xl font-black text-gray-900 leading-tight mb-6">
        스마트한 비즈니스의<br>
        <span class="text-brand-600">시작, 설성클라우드</span>
      </h1>
      <p class="text-lg text-gray-500 leading-relaxed mb-10 max-w-2xl mx-auto">
        빠르고 안정적인 클라우드 인프라로 비즈니스의 성장을 함께합니다.<br class="hidden md:block">
        복잡한 서버 관리는 저희에게 맡기고 비즈니스 본연에 집중하세요.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="#contact" class="w-full sm:w-auto px-8 py-3.5 bg-brand-600 text-white rounded-xl font-semibold hover:bg-brand-700 transition-colors shadow-lg shadow-brand-200">
          무료로 시작하기
        </a>
        <a href="#services" class="w-full sm:w-auto px-8 py-3.5 bg-white text-gray-700 rounded-xl font-semibold hover:bg-gray-50 border border-gray-200 transition-colors">
          서비스 알아보기
        </a>
      </div>
    </div>
  </section>

  <!-- Stats bar -->
  <section class="bg-white border-y border-gray-100 py-8 px-6">
    <div class="max-w-4xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
      <div>
        <p class="text-2xl font-black text-brand-600">99.9%</p>
        <p class="text-sm text-gray-500 mt-1">서비스 가동률</p>
      </div>
      <div>
        <p class="text-2xl font-black text-brand-600">2,400+</p>
        <p class="text-sm text-gray-500 mt-1">활성 고객사</p>
      </div>
      <div>
        <p class="text-2xl font-black text-brand-600">15ms</p>
        <p class="text-sm text-gray-500 mt-1">평균 응답속도</p>
      </div>
      <div>
        <p class="text-2xl font-black text-brand-600">24/7</p>
        <p class="text-sm text-gray-500 mt-1">기술 지원</p>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section id="services" class="py-20 px-6 bg-gray-50">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-14 fade-in">
        <p class="text-xs font-bold text-brand-600 tracking-widest uppercase mb-3">Services</p>
        <h2 class="text-3xl font-black text-gray-900 mb-4">비즈니스에 필요한 모든 것</h2>
        <p class="text-gray-500">확장 가능한 인프라와 강력한 관리 도구를 제공합니다.</p>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        <div class="service-card bg-white rounded-2xl p-6 border border-gray-100">
          <div class="w-12 h-12 bg-blue-50 rounded-xl flex items-center justify-center text-2xl mb-5">⚡</div>
          <h3 class="font-bold text-gray-900 mb-2">고성능 컴퓨팅</h3>
          <p class="text-sm text-gray-500 leading-relaxed">최신 하드웨어 기반의 고성능 서버로 어떤 워크로드도 빠르게 처리합니다.</p>
        </div>
        <div class="service-card bg-white rounded-2xl p-6 border border-gray-100">
          <div class="w-12 h-12 bg-green-50 rounded-xl flex items-center justify-center text-2xl mb-5">🔒</div>
          <h3 class="font-bold text-gray-900 mb-2">보안 & 컴플라이언스</h3>
          <p class="text-sm text-gray-500 leading-relaxed">엔터프라이즈급 보안과 데이터 암호화로 비즈니스 데이터를 안전하게 보호합니다.</p>
        </div>
        <div class="service-card bg-white rounded-2xl p-6 border border-gray-100">
          <div class="w-12 h-12 bg-purple-50 rounded-xl flex items-center justify-center text-2xl mb-5">📊</div>
          <h3 class="font-bold text-gray-900 mb-2">실시간 모니터링</h3>
          <p class="text-sm text-gray-500 leading-relaxed">직관적인 대시보드로 인프라 상태를 실시간으로 모니터링하고 관리합니다.</p>
        </div>
        <div class="service-card bg-white rounded-2xl p-6 border border-gray-100">
          <div class="w-12 h-12 bg-yellow-50 rounded-xl flex items-center justify-center text-2xl mb-5">🌐</div>
          <h3 class="font-bold text-gray-900 mb-2">글로벌 네트워크</h3>
          <p class="text-sm text-gray-500 leading-relaxed">전 세계 데이터센터를 통해 사용자에게 최적의 응답 속도를 제공합니다.</p>
        </div>
        <div class="service-card bg-white rounded-2xl p-6 border border-gray-100">
          <div class="w-12 h-12 bg-red-50 rounded-xl flex items-center justify-center text-2xl mb-5">🔄</div>
          <h3 class="font-bold text-gray-900 mb-2">자동 백업</h3>
          <p class="text-sm text-gray-500 leading-relaxed">자동화된 백업과 복구 시스템으로 데이터 손실 걱정 없이 운영하세요.</p>
        </div>
        <div class="service-card bg-white rounded-2xl p-6 border border-gray-100">
          <div class="w-12 h-12 bg-indigo-50 rounded-xl flex items-center justify-center text-2xl mb-5">📈</div>
          <h3 class="font-bold text-gray-900 mb-2">자동 스케일링</h3>
          <p class="text-sm text-gray-500 leading-relaxed">트래픽 변화에 따라 자동으로 리소스를 조정해 비용을 최적화합니다.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Dashboard preview -->
  <section id="dashboard" class="py-20 px-6 bg-white">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-12 fade-in">
        <p class="text-xs font-bold text-brand-600 tracking-widest uppercase mb-3">Dashboard</p>
        <h2 class="text-3xl font-black text-gray-900 mb-4">한눈에 보는 비즈니스 현황</h2>
        <p class="text-gray-500">직관적인 대시보드로 모든 지표를 실시간으로 확인하세요.</p>
      </div>

      <!-- Window mockup -->
      <div class="bg-white rounded-2xl shadow-xl border border-gray-100 overflow-hidden fade-in">
        <div class="flex items-center gap-2 px-5 py-4 border-b border-gray-100 bg-gray-50">
          <span class="w-3 h-3 rounded-full bg-red-400"></span>
          <span class="w-3 h-3 rounded-full bg-yellow-400"></span>
          <span class="w-3 h-3 rounded-full bg-green-400"></span>
          <span class="ml-3 text-sm font-medium text-gray-500">설성클라우드 대시보드</span>
        </div>
        <div class="p-6 space-y-5">
          <div class="grid grid-cols-3 gap-4">
            <div class="bg-indigo-50 rounded-xl p-5">
              <p class="text-sm text-gray-500 mb-2">클라우드 사용량</p>
              <p class="text-3xl font-bold text-blue-600 mb-3">84<span class="text-xl">%</span></p>
              <div class="w-full bg-blue-100 rounded-full h-1.5">
                <div class="bg-blue-500 h-1.5 rounded-full" style="width: 84%"></div>
              </div>
            </div>
            <div class="bg-green-50 rounded-xl p-5">
              <p class="text-sm text-gray-500 mb-2">월간 거래액</p>
              <p class="text-3xl font-bold text-green-600 mb-1">12.4<span class="text-xl">억</span></p>
              <p class="text-sm text-green-500">▲ 18.3% 성장</p>
            </div>
            <div class="bg-purple-50 rounded-xl p-5">
              <p class="text-sm text-gray-500 mb-2">서비스 가동률</p>
              <p class="text-3xl font-bold text-purple-600 mb-1">99.9<span class="text-xl">%</span></p>
              <p class="text-sm text-purple-500 flex items-center gap-1">
                <span class="w-2 h-2 rounded-full bg-purple-500 inline-block"></span>
                정상 운영 중
              </p>
            </div>
          </div>
          <div class="grid grid-cols-2 gap-4">
            <div class="border border-gray-100 rounded-xl p-5">
              <p class="text-sm font-medium text-gray-600 mb-4">실시간 주문 현황</p>
              <div class="space-y-3">
                <div class="flex justify-between"><span class="text-sm text-gray-600">스마트 스토어 A</span><span class="text-sm font-semibold text-green-500">+24</span></div>
                <div class="flex justify-between"><span class="text-sm text-gray-600">모바일 커머스 B</span><span class="text-sm font-semibold text-green-500">+67</span></div>
                <div class="flex justify-between"><span class="text-sm text-gray-600">멤버십 C</span><span class="text-sm font-semibold text-green-500">+13</span></div>
              </div>
            </div>
            <div class="border border-gray-100 rounded-xl p-5">
              <p class="text-sm font-medium text-gray-600 mb-4">인프라 상태</p>
              <div class="space-y-3">
                <div class="flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-green-400"></span><span class="text-sm text-gray-600">서울 리전 정상</span></div>
                <div class="flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-green-400"></span><span class="text-sm text-gray-600">DB 클러스터 정상</span></div>
                <div class="flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-green-400"></span><span class="text-sm text-gray-600">CDN 응답 양호</span></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section id="testimonials" class="py-20 px-6 bg-gray-50">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-14 fade-in">
        <p class="text-xs font-bold text-brand-600 tracking-widest uppercase mb-3">Testimonials</p>
        <h2 class="text-3xl font-black text-gray-900 mb-4">고객들의 이야기</h2>
        <p class="text-gray-500">설성클라우드와 함께 성장한 기업들의 생생한 후기입니다.</p>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        <div class="testimonial-card bg-white rounded-2xl p-6 border border-gray-100">
          <div class="flex items-center gap-1 text-yellow-400 mb-4">★★★★★</div>
          <p class="text-sm text-gray-600 leading-relaxed mb-5">"서버 장애 걱정 없이 비즈니스에만 집중할 수 있게 됐습니다. 응답 속도도 이전 대비 3배 향상됐어요."</p>
          <div class="flex items-center gap-3">
            <div class="w-9 h-9 bg-brand-100 rounded-full flex items-center justify-center text-brand-600 font-bold text-sm">김</div>
            <div>
              <p class="text-sm font-semibold text-gray-800">김민준 대표</p>
              <p class="text-xs text-gray-400">이커머스 스타트업</p>
            </div>
          </div>
        </div>
        <div class="testimonial-card bg-white rounded-2xl p-6 border border-gray-100">
          <div class="flex items-center gap-1 text-yellow-400 mb-4">★★★★★</div>
          <p class="text-sm text-gray-600 leading-relaxed mb-5">"트래픽 폭증 시에도 자동 스케일링 덕분에 단 한 번의 장애도 없었습니다. 정말 믿음직합니다."</p>
          <div class="flex items-center gap-3">
            <div class="w-9 h-9 bg-green-100 rounded-full flex items-center justify-center text-green-600 font-bold text-sm">이</div>
            <div>
              <p class="text-sm font-semibold text-gray-800">이서연 CTO</p>
              <p class="text-xs text-gray-400">핀테크 기업</p>
            </div>
          </div>
        </div>
        <div class="testimonial-card bg-white rounded-2xl p-6 border border-gray-100">
          <div class="flex items-center gap-1 text-yellow-400 mb-4">★★★★★</div>
          <p class="text-sm text-gray-600 leading-relaxed mb-5">"24시간 기술 지원팀이 항상 빠르게 대응해줍니다. 비용도 합리적이어서 만족도가 매우 높습니다."</p>
          <div class="flex items-center gap-3">
            <div class="w-9 h-9 bg-purple-100 rounded-full flex items-center justify-center text-purple-600 font-bold text-sm">박</div>
            <div>
              <p class="text-sm font-semibold text-gray-800">박지훈 팀장</p>
              <p class="text-xs text-gray-400">물류 플랫폼</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section id="contact" class="py-20 px-6 bg-white">
    <div class="max-w-2xl mx-auto">
      <div class="text-center mb-12 fade-in">
        <p class="text-xs font-bold text-brand-600 tracking-widest uppercase mb-3">Contact</p>
        <h2 class="text-3xl font-black text-gray-900 mb-4">지금 바로 시작하세요</h2>
        <p class="text-gray-500">14일 무료 체험, 신용카드 불필요. 문의사항을 남겨주세요.</p>
      </div>
      <form class="space-y-4 fade-in" onsubmit="handleSubmit(event)">
        <div class="grid sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5">이름</label>
            <input type="text" placeholder="홍길동" class="w-full px-4 py-2.5 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-brand-300 focus:border-brand-400 transition-all">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5">회사명</label>
            <input type="text" placeholder="(주)설성" class="w-full px-4 py-2.5 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-brand-300 focus:border-brand-400 transition-all">
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">이메일</label>
          <input type="email" placeholder="example@company.com" class="w-full px-4 py-2.5 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-brand-300 focus:border-brand-400 transition-all">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">문의 내용</label>
          <textarea rows="4" placeholder="문의하실 내용을 입력해주세요." class="w-full px-4 py-2.5 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-brand-300 focus:border-brand-400 transition-all resize-none"></textarea>
        </div>
        <button type="submit" class="w-full py-3.5 bg-brand-600 text-white rounded-xl font-semibold hover:bg-brand-700 transition-colors shadow-lg shadow-brand-200">
          문의 보내기
        </button>
      </form>
    </div>
  </section>

  <!-- Footer -->
  <footer class="bg-gray-900 text-gray-400 py-10 px-6">
    <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center justify-between gap-4">
      <div class="flex items-center gap-2">
        <div class="w-7 h-7 bg-brand-500 rounded-lg flex items-center justify-center text-white font-bold text-xs">S</div>
        <span class="text-white font-bold">설성클라우드</span>
      </div>
      <p class="text-sm">© 2025 Sulsung Cloud. All rights reserved.</p>
      <div class="flex gap-6 text-sm">
        <a href="#" class="hover:text-white transition-colors">이용약관</a>
        <a href="#" class="hover:text-white transition-colors">개인정보처리방침</a>
        <a href="#contact" class="hover:text-white transition-colors">문의하기</a>
      </div>
    </div>
  </footer>

  <script>
    // Hamburger menu
    document.getElementById('hamburger').addEventListener('click', function() {
      const menu = document.getElementById('mobile-menu');
      menu.classList.toggle('hidden');
    });

    // Close mobile menu on link click
    document.querySelectorAll('#mobile-menu a').forEach(link => {
      link.addEventListener('click', () => {
        document.getElementById('mobile-menu').classList.add('hidden');
      });
    });

    // Smooth scroll
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
      anchor.addEventListener('click', function(e) {
        const target = document.querySelector(this.getAttribute('href'));
        if (target) {
          e.preventDefault();
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });
    });

    // Intersection observer for fade-in
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));

    // Form handler
    function handleSubmit(e) {
      e.preventDefault();
      const btn = e.target.querySelector('button[type="submit"]');
      btn.textContent = '전송 완료! ✓';
      btn.classList.remove('bg-brand-600', 'hover:bg-brand-700');
      btn.classList.add('bg-green-500');
      setTimeout(() => {
        btn.textContent = '문의 보내기';
        btn.classList.add('bg-brand-600', 'hover:bg-brand-700');
        btn.classList.remove('bg-green-500');
        e.target.reset();
      }, 3000);
    }
  </script>

</body>
</html>
